{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": false,
    "outDir": "./dist-worker-tests",
    "rootDir": ".",
    "types": [
      "node",
      "@cloudflare/workers-types",
      "@cloudflare/vitest-pool-workers/types"
    ]
  },
  "include": [
    "src/**/*.ts",
    "tests/worker/**/*.ts",
    "vitest.worker.config.ts",
    "workers/**/*.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
