{
  "name": "@tabula-md/mcp",
  "version": "0.1.0",
  "description": "Local MCP server for joining Tabula.md encrypted collaboration rooms.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "tabula-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
