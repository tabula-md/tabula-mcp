{
  "name": "@tabula-md/mcp",
  "version": "0.6.2",
  "description": "Connect Codex, Claude, and other MCP clients to shared Tabula workspaces.",
  "license": "MIT",
  "author": {
    "name": "Tabula",
    "url": "https://tabula.md"
  },
  "homepage": "https://tabula.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tabula-md/tabula-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/tabula-md/tabula-mcp/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "tabula",
    "markdown",
    "collaboration",
    "mcp",
    "mcp-app",
    "encrypted-rooms"
  ],
  "type": "module",
  "bin": {
    "tabula-mcp": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    },
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "default": "./dist/protocol.js"
    }
  },
  "files": [
    "assets/icon.png",
    "dist/**/*.d.ts",
    "dist/**/*.js",
    "dist/document-app.html",
    "!dist/mcpb",
    "!dist/mcpb/**",
    "!dist/*.mcpb",
    "!dist/*.mcpb.sha256",
    "README.md",
    "PRIVACY.md",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "CHANGELOG.md",
    "release-manifest.json"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && npm run build:app && tsc -p tsconfig.json",
    "build:app": "vite build --config vite.config.app.mjs",
    "check:exports": "node scripts/check-package-exports.mjs",
    "check:vercel": "node -e \"JSON.parse(require('node:fs').readFileSync('vercel.json','utf8'))\" && npm run build && node --import tsx scripts/smoke-vercel-entrypoint.mjs",
    "check:cloudflare": "npx wrangler deploy --dry-run --outdir /tmp/tabula-mcp-wrangler-dry-run",
    "check:claude-plugin": "node scripts/check-claude-marketplace.mjs",
    "check:deploy-targets": "npm run check:vercel && npm run check:cloudflare",
    "check:context-budget": "npm run build && node scripts/measure-mcp-context.mjs --check",
    "check:p0-invariants": "vitest run tests/operational-policy.test.ts tests/operation-ledger.test.ts tests/workspace-file-service.test.ts tests/share.test.ts tests/cloudflare-quota.test.ts tests/cloudflare-session-do.test.ts tests/registry.test.ts tests/mcp-workflows.test.ts",
    "check:secret-boundaries": "node scripts/check-secret-boundaries.mjs",
    "check:mcpb": "node scripts/check-mcpb.mjs",
    "check:mcpb-tools": "npm run build && node scripts/sync-mcpb-tool-metadata.mjs --check",
    "check:pack": "node scripts/check-npm-pack.mjs",
    "build:mcpb": "npm run build && node scripts/build-mcpb.mjs",
    "sync:mcpb-tools": "npm run build && node scripts/sync-mcpb-tool-metadata.mjs --write",
    "deploy:cloudflare": "npx wrangler deploy",
    "deploy:vercel": "npx vercel deploy --prod",
    "dev:app": "vite --config vite.config.dev.mjs",
    "dev": "npm run build:app && tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "npm run build:app && vitest run",
    "build:worker:test": "wrangler deploy --dry-run --outdir dist/worker-test-bundle --upload-source-maps=false",
    "test:worker": "npm run typecheck:worker && npm run build:worker:test && vitest run --config vitest.worker.config.ts",
    "test:app": "npm run build:app && node scripts/smoke-mcp-app.mjs && npm run test:app:flow",
    "test:app:flow": "node scripts/smoke-mcp-app-flow.mjs",
    "test:e2e:local-collab": "npm run build && node scripts/e2e-local-collab.mjs",
    "test:stdio": "npm run build && node scripts/smoke-stdio-server.mjs",
    "check:release-contract": "node scripts/check-release-contract.mjs",
    "check:release-workflow": "node scripts/check-release-workflow.mjs",
    "check:release-artifacts": "node scripts/check-release-artifacts.mjs",
    "build:release-manifest": "node scripts/build-release-manifest.mjs",
    "release:pack": "node scripts/pack-release.mjs && npm run build:release-manifest && npm run check:release-artifacts && npm run check:claude-plugin",
    "release:verify": "npm run check:release-contract && npm run check:release-workflow && npm run typecheck && npm run check:p0-invariants && npm run test:worker && npm run check:secret-boundaries && npm test && npm run test:app && npm run test:stdio && npm run check:context-budget && npm run check:mcpb-tools && npm run check:deploy-targets && npm run release:pack && npm run check:exports && npm run check:pack && npm audit --json && git diff --check",
    "release:verify:full": "npm run release:verify && npm run test:e2e:local-collab",
    "prepublishOnly": "npm run release:verify",
    "measure:mcp-context": "npm run build && node scripts/measure-mcp-context.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:worker": "tsc -p tsconfig.worker-tests.json --noEmit"
  },
  "dependencies": {
    "@firebase/app": "^0.15.1",
    "@firebase/firestore": "^4.16.0",
    "@firebase/storage": "^0.14.3",
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tabula-md/tabula": "0.7.0",
    "lib0": "^0.2.117",
    "socket.io-client": "^4.8.3",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.27",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^2.1.2",
    "@cloudflare/vitest-pool-workers": "^0.18.6",
    "@cloudflare/workers-types": "^5.20260718.1",
    "@types/node": "^22.10.0",
    "playwright": "^1.61.1",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "tmp": "^0.2.6"
  }
}
